# ── boe_landing_backend configuration (server-side only) ─────────────────────
# Copy to .env and adjust. Every value has a safe local default.

# Port the API binds to. The landing page proxies /v1 -> this host (default).
PORT=47502

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection URL string. Local example shown; for MongoDB Atlas use the SRV URI:
#   mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=mongodb://127.0.0.1:27017

# Database name used within the MongoDB server.
MONGODB_DB=boe_landing

# Secret used to sign JWT access/refresh tokens. CHANGE THIS in production.
JWT_SECRET=change-me-to-a-long-random-string

# Shared secret the landing server sends as the x-signup-key header on
# /v1/auth/signup. Must match the landing page's SIGNUP_PROXY_SECRET.
SIGNUP_PROXY_SECRET=change-me-to-a-long-random-string

# Fallback gate used only when SIGNUP_PROXY_SECRET is empty: the Origin allowed
# to call /v1/auth/signup.
SIGNUP_ALLOWED_ORIGIN=http://127.0.0.1:3100

# Set to "true" when served over HTTPS so auth cookies carry the Secure flag.
COOKIE_SECURE=false
